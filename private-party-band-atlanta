<!-- WHAT MAKES US UNIQUE -->
<section style="padding:64px 60px;background:linear-gradient(135deg,rgba(255,45,120,0.08),rgba(255,214,10,0.04),rgba(0,245,212,0.06));border-top:1px solid var(--border);">
