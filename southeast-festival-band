<style>:root{
  --dark:#080d18;--darker:#050810;
  --teal:#00f5d4;--teal-dim:#00c4aa;
  --pink:#ff2d78;--gold:#ffd60a;--warm:#ff6b35;
  --white:#ffffff;--off-white:#e0fff8;
  --muted:rgba(255,255,255,0.6);
  --card:rgba(255,255,255,0.05);
  --border:rgba(0,245,212,0.25);
  --glow:0 0 40px rgba(0,245,212,0.3);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Nunito',sans-serif;background:var(--dark);color:var(--white);overflow-x:hidden;}
a{color:inherit;text-decoration:none;}
@keyframes phone-flash{
  0%,100%{color:var(--teal);text-shadow:0 0 20px rgba(0,245,212,0.4);}
  50%{color:#fff;text-shadow:0 0 40px rgba(0,245,212,1),0 0 80px rgba(0,245,212,0.6);}
}
header{position:fixed;top:0;left:0;right:0;z-index:200;padding:10px 48px;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(8,13,24,0.95);backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);}
.hlogo{display:flex;align-items:center;}
.hlogo-img{height:56px;width:auto;object-fit:contain;
  filter:drop-shadow(0 0 14px rgba(0,245,212,0.6));}
.hphone{text-align:right;}
.hphone .label{font-size:10px;color:var(--muted);text-transform:uppercase;
  letter-spacing:.14em;font-weight:700;}
.hphone a{display:block;font-family:'Bebas Neue',sans-serif;font-size:28px;
  letter-spacing:.04em;line-height:1.1;animation:phone-flash 1.8s ease-in-out infinite;}
.btn{display:inline-flex;align-items:center;gap:8px;padding:13px 30px;
  border-radius:4px;font-family:'Bebas Neue',sans-serif;font-size:20px;
  letter-spacing:.06em;transition:all .2s;white-space:nowrap;cursor:pointer;border:none;}
.btn-teal{background:var(--teal);color:var(--dark);box-shadow:0 0 24px rgba(0,245,212,0.35);}
.btn-teal:hover{background:var(--teal-dim);transform:translateY(-2px);}
.btn-gold{background:var(--gold);color:var(--dark);box-shadow:0 0 24px rgba(255,214,10,0.35);}
.btn-gold:hover{background:#e6c000;transform:translateY(-2px);}
.btn-pink{background:var(--pink);color:#fff;box-shadow:0 0 24px rgba(255,45,120,0.35);}
.btn-pink:hover{background:#e0005f;transform:translateY(-2px);}
.btn-out{background:transparent;border:2px solid var(--teal);color:var(--teal);
  font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:.06em;
  padding:11px 26px;border-radius:4px;display:inline-flex;align-items:center;gap:8px;
  transition:all .2s;}
.btn-out:hover{background:var(--teal);color:var(--dark);}
.form-box{background:rgba(255,255,255,0.04);border:1px solid var(--border);
  border-radius:16px;padding:40px;}
.form-box h3{font-family:'Bebas Neue',sans-serif;font-size:30px;letter-spacing:.06em;
  color:var(--teal);margin-bottom:4px;}
.form-box .sub{color:var(--muted);font-size:12px;font-weight:700;
  text-transform:uppercase;letter-spacing:.1em;margin-bottom:28px;display:block;}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.fg{display:flex;flex-direction:column;gap:5px;margin-bottom:14px;}
.fg label{font-size:10px;font-weight:800;text-transform:uppercase;
  letter-spacing:.14em;color:var(--teal);}
.fg input,.fg select,.fg textarea{
  background:rgba(0,245,212,0.05);border:1px solid rgba(0,245,212,0.2);
  border-radius:4px;padding:11px 13px;color:#fff;
  font-family:'Nunito',sans-serif;font-size:14px;font-weight:600;transition:border-color .2s;
  width:100%;box-sizing:border-box;}
.fg input:focus,.fg select:focus,.fg textarea:focus{
  outline:none;border-color:var(--teal);box-shadow:0 0 0 3px rgba(0,245,212,0.1);}
.fg select option{background:#080d18;}
.fg textarea{height:96px;resize:vertical;}
.hp{display:none!important;}
.btn-submit{width:100%;padding:15px;border:none;border-radius:4px;
  font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:.08em;
  cursor:pointer;transition:all .2s;}
.ok{display:none;text-align:center;padding:20px;color:var(--teal);font-weight:800;font-size:15px;}
.err{display:none;text-align:center;padding:14px;color:var(--pink);font-size:14px;font-weight:700;}
footer{background:var(--darker);border-top:1px solid var(--border);
  padding:28px 60px;text-align:center;}
footer p{color:var(--muted);font-size:13px;}
footer a{color:var(--teal);font-weight:700;}
.socials{display:flex;justify-content:center;gap:24px;margin-bottom:14px;flex-wrap:wrap;}
.socials a{color:var(--muted);font-size:12px;font-weight:800;letter-spacing:.1em;
  text-transform:uppercase;transition:color .2s;}
.socials a:hover{color:var(--teal);}
.sticky{position:fixed;bottom:0;left:0;right:0;z-index:999;
  background:linear-gradient(90deg,var(--pink),var(--teal));
  color:var(--dark);padding:10px 24px;
  display:flex;align-items:center;justify-content:center;gap:16px;
  transform:translateY(100%);transition:transform .3s;}
.sticky.on{transform:translateY(0);}
.sticky p{font-weight:800;font-size:14px;margin:0;}
.sticky-btn{background:var(--dark);color:var(--teal);padding:7px 20px;border-radius:50px;
  font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:.04em;white-space:nowrap;}
.sticky-x{background:none;border:none;color:rgba(8,13,24,0.6);font-size:20px;
  cursor:pointer;margin-left:8px;}
@media(max-width:768px){
  html,body{overflow-x:hidden!important;max-width:100vw!important;width:100%!important;}
  *:not(.hero-bg):not(.fhero-bg):not(.chero-img){max-width:100%;box-sizing:border-box;}
  header{padding:10px 20px;}
  nav{display:none!important;}
  .frow{grid-template-columns:1fr;}
  footer{padding:24px 20px;}
  .sticky p{display:none;}
  .pricing-grid{grid-template-columns:1fr!important;}
  .hero{padding:100px 20px 60px!important;min-height:80vh;position:relative;overflow:hidden;width:100%;}
  .hero-bg{background-size:cover!important;background-position:center center!important;
    position:absolute!important;inset:0!important;width:100%!important;height:100%!important;
    max-width:none!important;}
  .fhero{padding:90px 20px 48px!important;min-height:55vh;position:relative;overflow:hidden;width:100%;}
  .fhero-bg{background-size:cover!important;background-position:center 25%!important;
    position:absolute!important;inset:0!important;width:100%!important;height:100%!important;
    max-width:none!important;}
  .fg input,.fg select,.fg textarea{width:100%!important;max-width:100%!important;box-sizing:border-box!important;}
  section[style*="padding"]{padding-left:20px!important;padding-right:20px!important;box-sizing:border-box;}
}
@media(max-width:860px){
  .chero{grid-template-columns:1fr;}
  .feats,.two,.fsec,.pro,.plug,.venues,.fform,.pform,.party-form,.fsec-in{
    grid-template-columns:1fr!important;padding-left:20px!important;padding-right:20px!important;}
  .fgrid,.pgrid,.wgrid,.ptypes{grid-template-columns:1fr!important;}
  .vgrid{grid-template-columns:1fr 1fr!important;}
  .mosaic{padding:0 20px!important;}
  [style*="grid-template-columns:repeat(4,1fr)"]{grid-template-columns:repeat(2,1fr)!important;}
  [style*="padding:72px 60px"],[style*="padding:64px 60px"],[style*="padding:56px 60px"]{
    padding-left:20px!important;padding-right:20px!important;}
}
</style>
