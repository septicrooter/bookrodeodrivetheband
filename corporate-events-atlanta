<style>:root{
  --dark:#080d18;--darker:#050810;
  --teal:#00f5d4;--teal-dim:#00c4aa;
  --pink:#ff2d78;--gold:#ffd60a;--warm:#ff6b35;
  --white:#ffffff;--off-white:#e0fff8;
  --muted:rgba(255,255,255,0.6);
  --card:rgba(255,255,255,0.05);
  --border:rgba(0,245,212,0.25);
  --glow:0 0 40px rgba(0,245,212,0.3);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Nunito',sans-serif;background:var(--dark);color:var(--white);overflow-x:hidden;}
a{color:inherit;text-decoration:none;}
@keyframes phone-flash{
  0%,100%{color:var(--teal);text-shadow:0 0 20px rgba(0,245,212,0.4);}
  50%{color:#fff;text-shadow:0 0 40px rgba(0,245,212,1),0 0 80px rgba(0,245,212,0.6);}
}
header{position:fixed;top:0;left:0;right:0;z-index:200;padding:10px 48px;
